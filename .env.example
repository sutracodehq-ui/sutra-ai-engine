# ─── App ────────────────────────────────────────
APP_NAME=SutraAI
APP_ENV=local
DEBUG=true

# ─── Database ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@sutra-ai-postgres:5432/sutra_ai

# ─── Redis ──────────────────────────────────────
REDIS_URL=redis://sutra-ai-redis:6379/0

# ─── Auth ───────────────────────────────────────
MASTER_API_KEY=sk_master_change_me_in_production

# ─── AI Driver (primary text completion) ────────
# SmartRouter auto-selects model tier (simple→mini, complex→pro)
# No need for separate refine/content drivers — SmartRouter handles it
AI_DRIVER=mock
AI_FALLBACK_DRIVER=gemini

# ─── Pipeline Routing (capability-specific) ─────
# Vision: used for image analysis, OCR, visual understanding
AI_VISION_DRIVER=gemini
AI_VISION_MODEL=gemini-2.0-flash
# Image generation: DALL-E, Imagen (completely different API)
AI_IMAGE_DRIVER=openai
AI_IMAGE_MODEL=dall-e-3

# ─── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# ─── Anthropic ──────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_TEMPERATURE=0.7

# ─── Google Gemini ──────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7

# ─── Groq ───────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.7

# ─── NVIDIA NIM ─────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_MAX_TOKENS=2048
NVIDIA_TEMPERATURE=0.7

# ─── Sarvam AI ──────────────────────────────────
SARVAM_API_KEY=
SARVAM_MODEL=sarvam-m
SARVAM_MAX_TOKENS=2048
SARVAM_TEMPERATURE=0.7

# ─── Together (OpenAI-compatible) ──────────────
TOGETHER_API_KEY=
TOGETHER_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo
TOGETHER_MAX_TOKENS=2048
TOGETHER_TEMPERATURE=0.7

# ─── Fireworks (OpenAI-compatible) ─────────────
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_MAX_TOKENS=2048
FIREWORKS_TEMPERATURE=0.7

# ─── Ollama ─────────────────────────────────────
OLLAMA_BASE_URL=http://sutra-ai-ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT_CONNECT=10
OLLAMA_TIMEOUT_READ=300

# ─── Qdrant (vector store — only supported vector backend) ───────────────────────
# ChromaDB is not used by sutra-ai-engine; do not set CHROMA_* for this service.
QDRANT_URL=http://sutra-ai-qdrant:6333
QDRANT_API_KEY=
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768

# ─── Cloudflare R2 ──────────────────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=sutra-ai-storage
R2_ENDPOINT=

# ─── Quality Gate ───────────────────────────────
AI_QUALITY_GATE_ENABLED=true
AI_QUALITY_GATE_THRESHOLD=6
AI_QUALITY_GATE_RETRIES=1

# ─── Caching ───────────────────────────────────
AI_PROMPT_CACHE_ENABLED=true
AI_PROMPT_CACHE_TTL=7200
AI_SEMANTIC_CACHE_ENABLED=true
AI_SEMANTIC_CACHE_THRESHOLD=0.83
AI_SEMANTIC_CACHE_TTL=28800

# ─── Smart Router ──────────────────────────────
AI_SMART_ROUTER_ENABLED=true
AI_MATRIX_PROFILE=balanced_default

# ─── Circuit Breaker ───────────────────────────
AI_CIRCUIT_BREAKER_THRESHOLD=3
AI_CIRCUIT_BREAKER_COOLDOWN=60

# ─── Rate Limits ───────────────────────────────
AI_RATE_LIMIT_RPM=30

# ─── Token Budget ──────────────────────────────
AI_TOKEN_BUDGET_ENABLED=true
AI_TOKEN_BUDGET_MONTHLY=500000

# ─── Auto Learning ─────────────────────────────
AI_AUTO_LEARNING_ENABLED=true
AI_META_PROMPT_ENABLED=true
AI_EDIT_ANALYSIS=true
AI_AB_TESTING=true
AI_EXPLORE_RATE=0.2

# ─── Celery ────────────────────────────────────
CELERY_BROKER_URL=redis://sutra-ai-redis:6379/1
CELERY_RESULT_BACKEND=redis://sutra-ai-redis:6379/2
